{
  "expo": {
    "name": "Finanzas App",
    "slug": "finanzas-app",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finanzas-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "autor": "Edinson Madrid",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.edinsondevs.finanzasapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "expo": {
      "web": {
        "bundler": "metro"
      }
    },
    "splash": {
      "image": "./assets/images/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
